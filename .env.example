# Supabase Configuration
# Get these values from your Supabase project dashboard under Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# The service role key is only used server-side for admin operations.
# NEVER expose this key client-side or commit it to version control.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
